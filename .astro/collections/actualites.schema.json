{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Title of the article/post"
    },
    "description": {
      "type": "string",
      "description": "Brief description or excerpt"
    },
    "pubDate": {
      "type": "string",
      "format": "date-time",
      "description": "Publication date"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time",
      "description": "Last updated date"
    },
    "heroImage": {
      "type": "string",
      "description": "Path to hero image"
    },
    "category": {
      "type": "string",
      "description": "Category of the actualite"
    }
  },
  "required": ["title", "description", "pubDate"]
}
