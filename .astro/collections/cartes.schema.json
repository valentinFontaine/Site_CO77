{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "title": {
      "type": "string"
    },
    "imagePath": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "bounds": {
      "minItems": 4,
      "maxItems": 4,
      "type": "array",
      "items": {
        "type": "number"
      },
      "description": "Map bounds as [swLat, swLng, neLat, neLng]"
    },
    "thumbnail": {
      "description": "Path to thumbnail image (PNG format)",
      "type": "string"
    },
    "coordinates": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "difficultyLevel": {
      "type": "string",
      "enum": [
        "Facile",
        "Moyen",
        "Difficile",
        "Expert"
      ]
    },
    "scale": {
      "type": "string"
    },
    "mapType": {
      "type": "string",
      "enum": [
        "Forêt",
        "Urbain",
        "Sprint",
        "Mixed"
      ]
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time"
    },
    "author": {
      "type": "string"
    },
    "region": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "bounds"
  ]
}