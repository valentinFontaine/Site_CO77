{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "contactEmail": {
      "type": "string",
      "format": "email",
      "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
    },
    "contactPhone": {
      "type": "string"
    },
    "website": {
      "type": "string",
      "format": "uri"
    },
    "president": {
      "type": "string"
    },
    "membersCount": {
      "type": "number"
    },
    "logoPath": {
      "type": "string"
    },
    "foundingYear": {
      "type": "number"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "description",
    "location"
  ]
}