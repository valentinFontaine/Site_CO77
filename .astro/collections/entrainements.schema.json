{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "rendezVous": {
      "type": "string"
    },
    "parkingInfo": {
      "type": "string"
    },
    "itinerary": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "duration": {
      "type": "string"
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "Facile",
        "Moyen",
        "Difficile"
      ]
    },
    "organizer": {
      "type": "string"
    },
    "maxParticipants": {
      "type": "number"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "rendezVous",
    "parkingInfo",
    "itinerary"
  ]
}