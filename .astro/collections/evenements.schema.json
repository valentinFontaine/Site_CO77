{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "location": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "price": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        }
      ]
    },
    "areasOfExpertise": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "results": {
      "type": "string"
    },
    "organizer": {
      "type": "string"
    },
    "registrationLink": {
      "type": "string",
      "format": "uri"
    },
    "maxParticipants": {
      "type": "number"
    },
    "startTime": {
      "type": "string"
    },
    "endTime": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "location"
  ]
}