---
interface Props {
  title?: string;
  items: Array<{
    href: string;
    label: string;
  }>;
}

const { title, items } = Astro.props;
---

<nav class="sub-nav" style="background: #f5f5f5; padding: 1rem; margin-bottom: 2rem; border-radius: 8px;">
  {title && <h3 style="margin: 0 0 1rem 0; padding: 0;">{title}</h3>}
  <ul style="list-style: none; padding: 0; margin: 0; display: flex; gap: 1.5rem; flex-wrap: wrap;">
    {
      items.map((item) => (
        <li>
          <a
            href={item.href}
            style="text-decoration: none; color: var(--black); padding: 0.5rem 1rem; border-radius: 4px; transition: background 0.2s;"
            class:list={[
              Astro.url.pathname.startsWith(item.href) ? 'active' : '',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .sub-nav ul li a.active {
    background: var(--accent);
    color: white;
  }
  .sub-nav ul li a:hover:not(.active) {
    background: #e0e0e0;
  }
</style>
