---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';

export async function getStaticPaths() {
  const posts = await getCollection('actualites');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await render(post);
---

<!doctype html>
<html lang="fr">
<head><BaseHead title={post.data.title} description={post.data.description} /></head>
<body>
<Header />
<main>
  <h1>{post.data.title}</h1>
  <p><FormattedDate date={post.data.pubDate} /></p>
  {post.data.heroImage && <Image src={post.data.heroImage} alt={post.data.title} style="max-width: 100%; margin: 1rem 0;" />}
  <Content />
</main>
<Footer />
</body>
</html>
