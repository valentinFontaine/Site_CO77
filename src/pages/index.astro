---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Bienvenue sur le site du CO77</h1>
			<p>
				Bienvenue sur le site officiel du <strong>Comité Départemental 77 de Course d'Orientation</strong>.
			</p>
			<p>
				Découvrez les activités, les clubs, les entraînements et les compétitions de course d'orientation 
				dans le département de Seine-et-Marne.
			</p>
			
			<h2>Nos sections</h2>
			<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin: 2rem 0;">
				<div style="border: 1px solid #ddd; padding: 1.5rem; border-radius: 8px;">
					<h3>La CO</h3>
					<p>Découvrez la course d'orientation et ses différentes facettes.</p>
					<a href="/la-co/" style="color: var(--accent);">En savoir plus →</a>
				</div>
				<div style="border: 1px solid #ddd; padding: 1.5rem; border-radius: 8px;">
					<h3>Actualités</h3>
					<p>Résultats, news, photos et portraits des orienteurs.</p>
					<a href="/actualites/" style="color: var(--accent);">En savoir plus →</a>
				</div>
				<div style="border: 1px solid #ddd; padding: 1.5rem; border-radius: 8px;">
					<h3>Cartographie</h3>
					<p>Nos cartes et parcours d'orientation.</p>
					<a href="/cartographie/" style="color: var(--accent);">En savoir plus →</a>
				</div>
				<div style="border: 1px solid #ddd; padding: 1.5rem; border-radius: 8px;">
					<h3>Missions du CD</h3>
					<p>Entraînements, matériel et organisation.</p>
					<a href="/missions-cd/" style="color: var(--accent);">En savoir plus →</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
