---
import BaseLayout from '../../layouts/BaseLayout.astro';
import cartes from '../../generated/cartes.json';

const title = 'Cartographie';
const description = 'Explorez nos cartes de course d\'orientation en Seine-et-Marne. Survolez les vignettes pour en savoir plus et cliquez pour ouvrir la fiche détaillée.';
---

<BaseLayout title={title} description={description}>
  <div class="container mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-4xl font-display font-bold text-ink mb-4">Cartographie En Seine et Marne</h1>
      <p class="text-lg text-gray-600 max-w-3xl">
        Explorez nos cartes de course d'orientation disponibles : survolez les vignettes pour en savoir plus et cliquez pour ouvrir la fiche détaillée.
      </p>
    </div>

    <!-- Map Container -->
    <div class="bg-paper rounded-lg shadow-lg overflow-hidden">
      <div id="map" class="w-full h-96 md:h-[600px]"></div>
    </div>

    
    <!-- Map Instructions -->
    <div class="mt-6 bg-surface rounded-lg p-6">
      <h2 class="text-xl font-display font-semibold mb-3">Comment utiliser la carte</h2>
      <ul class="space-y-2 text-gray-700">
        <li class="flex items-start">
          <span class="text-brand mr-2">•</span>
          <span>Utilisez les contrôles en haut à droite pour changer de fond de carte (IGN Plan ou OpenStreetMap)</span>
        </li>
        <li class="flex items-start">
          <span class="text-brand mr-2">•</span>
          <span>Survolez les vignettes de cartes pour voir les détails</span>
        </li>
        <li class="flex items-start">
          <span class="text-brand mr-2">•</span>
          <span>Cliquez sur une vignette pour accéder à la fiche complète de la carte</span>
        </li>
        <li class="flex items-start">
          <span class="text-brand mr-2">•</span>
          <span>Zoomez et déplacez-vous pour explorer toute la Seine-et-Marne</span>
        </li>
      </ul>
    </div>

    <!-- Acheter des cartes -->
    <section class="mt-8">
      <div class="bg-paper rounded-lg shadow-md p-6">
        <h2 class="text-2xl font-display font-semibold mb-4">Acheter des cartes de course d'orientation</h2>
        <p class="text-gray-700 mb-4">
          Les cartes disponibles à l'achat sont représentées sur la carte interactive ci-dessus. 
          Après avoir consulté l'inventaire des cartes du CDCO77, veuillez vous adresser directement au propriétaire de la carte.
        </p>
        <div class="bg-blue-50 border-l-4 border-blue-400 p-4 mb-4">
          <h3 class="font-semibold text-blue-800 mb-2">Pour les cartes appartenant au CDCO77</h3>
          <p class="text-blue-700 text-sm mb-2">Prendre contact auprès du responsable cartographique :</p>
          <div class="text-blue-800">
            <p class="font-semibold">Etienne MOREY</p>
            <p>📞 06.07.43.21.97</p>
            <p>📧 <a href="mailto:etienne.morey@neuf.fr" class="hover:underline">etienne.morey@neuf.fr</a></p>
          </div>
        </div>
        <div class="text-sm text-gray-600">
          <p>
            Consultez également la page d'inventaire des cartes du CDCO77 sur le site FFCO : 
            <a href="https://www.ffcorientation.fr/licencie/cartographie/cartotheque/liste/?cd=77" 
               class="text-brand hover:underline" target="_blank" rel="noopener noreferrer">
              Cartothèque FFCO - Département 77
            </a>
          </p>
        </div>
      </div>
    </section>

    <!-- Ressources pour les clubs CDCO77 -->
    <section class="mt-8">
      <div class="bg-paper rounded-lg shadow-md p-6">
        <h2 class="text-2xl font-display font-semibold mb-4">Ressources pour les clubs du CDCO77</h2>
        <p class="text-gray-700 mb-6">
          Outils et ressources à destination des clubs affiliés au CDCO77 pour la création et le partage de cartes.
        </p>
        
        <div class="grid md:grid-cols-2 gap-6">
          <div class="space-y-4">
            <h3 class="text-lg font-semibold text-brand">Partage des cartes</h3>
            <div class="space-y-3">
              <a href="https://drive.google.com/drive/folders/1cnnNO6GYUxPZ3dVjsCl1UCVYkunPvPmG?usp=sharing" 
                 class="flex items-center text-brand hover:underline" target="_blank" rel="noopener noreferrer">
                📁 Dossier de partage des cartes
              </a>
              <a href="#" class="flex items-center text-brand hover:underline">
                📄 Convention partage et suivi des cartes du 77
              </a>
            </div>
          </div>
          
          <div class="space-y-4">
            <h3 class="text-lg font-semibold text-brand">Création de cartes</h3>
            <div class="space-y-3">
              <a href="#" class="flex items-center text-brand hover:underline">
                📚 Tutoriel CARTO CDCO77 2021
              </a>
              <a href="#" class="flex items-center text-brand hover:underline">
                🎨 Valise de logos 2022
              </a>
            </div>
          </div>
        </div>
        
        <div class="mt-6 p-4 bg-yellow-50 border-l-4 border-yellow-400">
          <h4 class="font-semibold text-yellow-800 mb-2">Déclaration de création de cartes</h4>
          <p class="text-yellow-700 text-sm">
            Pensez à déclarer vos nouvelles cartes auprès de la FFCO et de la LIFCO selon la procédure en vigueur.
          </p>
        </div>
      </div>
    </section>
  </div>

  <script>
    // Import and initialize the map
    import { mountMap } from '../../components/Map/LeafletMap.ts';
    import { addCarteOverlays } from '../../components/Map/Overlays.ts';
    import cartes from '../../generated/cartes.json';

    document.addEventListener('DOMContentLoaded', async () => {
      const mapElement = document.getElementById('map') as HTMLDivElement;
      if (mapElement) {
        const map = mountMap(mapElement, [48.4545, 2.6532], 11);
        addCarteOverlays(map, cartes);
      }
    });
  </script>

  <style>
    /* Custom tooltip styles */
    :global(.custom-tooltip) {
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
      font-family: 'Source Sans 3', sans-serif;
    }
    
    :global(.custom-tooltip .leaflet-tooltip-content) {
      margin: 0;
      padding: 0;
    }
  </style>
</BaseLayout>
